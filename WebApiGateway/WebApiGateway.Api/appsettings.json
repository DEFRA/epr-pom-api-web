{
  "Serilog": {
    "Using": [
      "Serilog",
      "Serilog.Sinks.ApplicationInsights"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.AspNetCore.Hosting.Diagnostics": "Warning",
        "Microsoft.AspNetCore.Routing": "Warning",
        "Microsoft.AspNetCore.Server.Kestrel": "Warning",
        "Microsoft.AspNetCore.StaticFiles": "Warning",
        "Microsoft.Identity": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext",
      "WithEnvironmentName",
      "WithProcessId"
    ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "{Timestamp:yyyy-MM-dd'T'HH:mm:ss.ffffff} {Level:u3} {Message:lj}{NewLine}{Properties}{NewLine}{Exception}",
          "theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console"
        }
      },
      {
        "Name": "ApplicationInsights",
        "Args": {
          "telemetryConverter": "Serilog.Sinks.ApplicationInsights.TelemetryConverters.TraceTelemetryConverter, Serilog.Sinks.ApplicationInsights"
        }
      }
    ]
  },
  "AllowedHosts": "*",
  "AccountApi": {
    "BaseUrl": "https://localhost:1234/api",
    "ClientId": "",
    "Timeout": 30
  },
  "SubmissionStatusApi": {
    "BaseUrl": "https://localhost:1234"
  },
  "AntivirusApi": {
    "BaseUrl": "https://localhost:1234",
    "SubscriptionKey": "",
    "TenantId": "",
    "ClientId": "",
    "ClientSecret": "",
    "Scope": "",
    "Timeout": 300,
    "EnableDirectAccess": false,
    "CollectionSuffix": ""
  },
  "LoggingApi": {
    "BaseUrl": "https://localhost:1234"
  },
  "AzureAdB2C": {
    "Instance": "",
    "Domain": "",
    "ClientId": "",
    "SignUpSignInPolicyId": ""
  },
  "StorageAccount": {
    "PomContainer": "pom-upload-container",
    "RegistrationContainer": "registration-upload-container",
    "SubsidiaryContainer": "subsidiary-upload-container",
    "AccreditationContainer": "accreditation-upload-container"
  },
  "PrnServiceApi": {
    "BaseUrl": "http://localhost:5168",
    "ClientId": "",
    "Timeout": 30
  },
  "CommonDataApi": {
    "BaseUrl": "http://localhost:5001",
    "Timeout": 30
  },
  "PaymentService": {
    "BaseUrl": "http://localhost:7107",
    "ClientId": ""
  },
  "Redis": {
    "ConnectionString": "",
    "TimeToLiveInMinutes": 720
  },
  "WasteObligations": {
    "TokenEndpoint": "http://localhost:9090/oauth2/v2.0/token",
    "ClientId": "client_id",
    "ClientSecret": "client_secret",
    "BaseAddress": "http://localhost:9090/"
  }
}